    <script>
// Particles
(function(){
  var c=document.getElementById('particles');
  if(!c) return;
  for(var i=0;i<18;i++){
    var p=document.createElement('div');
    p.className='particle';
    p.style.left=Math.random()*100+'%';
    p.style.width=p.style.height=(1+Math.random()*2)+'px';
    p.style.setProperty('--dur',(6+Math.random()*8)+'s');
    p.style.setProperty('--delay',(Math.random()*8)+'s');
    p.style.setProperty('--drift',((Math.random()-.5)*80)+'px');
    c.appendChild(p);
  }
})();

// Nav scroll
window.addEventListener('scroll',function(){
  var nav = document.getElementById('mainNav');
  if(nav) nav.classList.toggle('scrolled',window.scrollY>20);
},{passive:true});

// Categories (Statik vitrin)
var cats=[
  {icon:'👕',name:'Giyim',count:'124 ürün'},
  {icon:'🏆',name:'Figürler',count:'87 ürün'},
  {icon:'💎',name:'Aksesuar',count:'95 ürün'},
  {icon:'🃏',name:'Koleksiyon',count:'63 ürün'},
  {icon:'🎁',name:'Hediyeler',count:'42 ürün'}
];
(function(){
  var g=document.getElementById('catGrid');
  if(g){
    cats.forEach(function(cat,i){
      var d=document.createElement('div');
      d.className='cat-card';
      d.style.animationDelay=(i*.08)+'s';
      d.innerHTML='<span class="cat-icon">'+cat.icon+'</span><div class="cat-name">'+cat.name+'</div><div class="cat-count">'+cat.count+'</div>';
      d.onclick=function(){showToast(cat.name+' kategorisine gidiliyor...');};
      g.appendChild(d);
    });
  }
})();

// Sepete Ekle Animasyonu (Shopify Gerçek Ürünler İçin)
function addToCartReal(btn) {
  if(btn.classList.contains('added')) return;
  var n = btn.getAttribute('data-name');
  btn.classList.add('added');
  btn.textContent = '✓';
  var cc = document.getElementById('cartCount');
  if(cc) cc.textContent = parseInt(cc.textContent) + 1;
  showToast(n + ' sepete eklendi!');
  setTimeout(function(){
    btn.classList.remove('added');
    btn.textContent = '+';
  }, 2000);
}

// Slider
var cur=0,total=3,timer=null;
function goToSlide(i){
  cur=(i+total)%total;
  var cont = document.getElementById('slidesContainer');
  if(cont) cont.style.transform='translateX(-'+(cur*100)+'%)';
  document.querySelectorAll('.slider-dot').forEach(function(d,idx){d.classList.toggle('active',idx===cur);});
}
function moveSlide(d){resetTimer();goToSlide(cur+d);}
function resetTimer(){
  clearInterval(timer);
  timer=setInterval(function(){goToSlide(cur+1);},4500);
}
resetTimer();

// Champion search
function filterChampions(){
  var input = document.getElementById('champSearchInput');
  if(!input) return;
  var v=input.value.toLowerCase();
  var items=document.getElementById('champListContainer').getElementsByClassName('champ-item');
  for(var i=0;i<items.length;i++){
    var n=items[i].getElementsByTagName('span')[0].innerText.toLowerCase();
    items[i].style.display=n.indexOf(v)>-1?'flex':'none';
  }
}

// Toast
var tTimer=null;
function showToast(msg){
  var t=document.getElementById('toast');
  var tMsg=document.getElementById('toastMsg');
  if(t && tMsg) {
    tMsg.textContent=msg;
    t.classList.add('show');
    clearTimeout(tTimer);
    tTimer=setTimeout(function(){t.classList.remove('show');},2800);
  }
}

// Scroll reveal
(function(){
  var els=document.querySelectorAll('.reveal');
  if(els.length > 0 && window.IntersectionObserver) {
    var obs=new IntersectionObserver(function(entries){
      entries.forEach(function(e){
        if(e.isIntersecting){
          e.target.classList.add('visible');
          obs.unobserve(e.target);
        }
      });
    },{threshold:.1});
    els.forEach(function(el){obs.observe(el);});
  }
})();
</script>
