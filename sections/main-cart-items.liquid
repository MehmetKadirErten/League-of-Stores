<div class="cart-container">
  <div class="cart-header">
    <div class="ornament-diamond" style="width:10px; height:10px; background: var(--gold-bright); transform: rotate(45deg);"></div>
    <h1 class="cart-title">Hextech Sepetİ</h1>
    <span class="cart-count-badge">{{ cart.item_count }} Ürün</span>
  </div>

  {% if cart.empty? %}
    <div style="text-align:center; padding: 100px 0; border: 1px dashed var(--border); background: rgba(0,0,0,0.3);">
      <h2 style="font-family:'Cinzel', serif; font-size: 32px; color:var(--gold-bright);">Sepetin Şu An Boş</h2>
      <p style="color:var(--gold-dark); margin-top:15px; margin-bottom: 35px; font-size: 16px;">Runeterra'nın eşsiz eserleri seni bekliyor. Vadiye dön ve kuşan!</p>
      <a href="{{ routes.root_url }}" class="btn-checkout" style="display:inline-block; width:auto; text-decoration:none; padding: 16px 40px;">Ana Sayfaya Dön</a>
    </div>
  {% else %}
    <form action="{{ routes.cart_url }}" method="post" id="cart-form" class="cart-layout">
      
      <div class="cart-items">
        {% for item in cart.items %}
          <div class="cart-item">
            <div class="item-img-wrap">
              {% if item.image %}
                <img src="{{ item.image | image_url: width: 150 }}" alt="{{ item.title | escape }}">
              {% else %}
                <span style="color:var(--gold-dark); font-size:10px; text-align:center;">Görsel<br>Yok</span>
              {% endif %}
            </div>
            
            <div class="item-info">
              <div class="item-vendor">{{ item.product.vendor | default: 'Runeterra' }}</div>
              <a href="{{ item.url }}" class="item-name">{{ item.product.title }}</a>
              {% unless item.product.has_only_default_variant %}
                <div class="item-variant">{{ item.variant.title }}</div>
              {% endunless %}
            </div>

            <div class="qty-control">
              <input type="number" name="updates[]" value="{{ item.quantity }}" class="qty-input" min="0">
            </div>

            <div class="item-price-wrap">
              <div class="item-price">{{ item.final_line_price | money }}</div>
            </div>

            <a href="{{ item.url_to_remove }}" class="remove-btn" title="Sepetten Çıkar" style="text-decoration:none;">✕</a>
          </div>
        {% endfor %}
        
        <button type="submit" name="update" class="update-cart-btn">Sepetİ Güncelle</button>
      </div>

      <div class="cart-summary">
        <div class="summary-title">Sipariş Özeti</div>
        
        <div class="summary-line">
          <span>Ara Toplam</span>
          <span>{{ cart.total_price | money }}</span>
        </div>
        <div class="summary-line">
          <span>Kargo (Runeterra İçi)</span>
          <span style="color: #5ADF8A;">Ücretsiz</span>
        </div>

        <div class="discount-section">
          <label class="discount-label">İndirim / Promosyon Kodu</label>
          <div class="discount-wrap">
            <input type="text" name="discount" class="discount-input" placeholder="Kodunuzu girin (örn. RIFTSTORE)">
          </div>
          <p style="font-size:10px; color:var(--gold-dark); margin-top:8px;">*Girdiğiniz kod ödeme adımında uygulanacaktır.</p>
        </div>

        <div class="summary-total">
          <span class="total-text">Toplam</span>
          <span class="total-price">{{ cart.total_price | money }}</span>
        </div>
        <div class="total-rp">Tahmini Değer: {{ cart.total_price | divided_by: 10 }} RP</div>

        <button type="submit" name="checkout" class="btn-checkout">Ödeme Adımına Geç</button>
        <a href="{{ routes.root_url }}" class="continue-shopping">← Alışverişe Dön</a>
      </div>
    </form>
  {% endif %}
</div>