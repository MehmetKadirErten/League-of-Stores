<div class="hero">
  <div class="hero-content">
    <div class="hero-tag">Sezon 2025 Koleksiyonu</div>
    <h1 class="hero-title">Runeterra'yı<br><span>Yanına Getir!</span></h1>
    <p class="hero-desc">Efsanevi şampiyonlardan ilham alan özel tasarım ürünler. Oyunun ruhunu günlük hayatına taşı.</p>
    <div class="hero-btns">
      <button class="btn-primary" onclick="showToast('Alışverişe yönlendiriliyorsunuz...')">Alışverişe Başla</button>
      <button class="btn-secondary" onclick="showToast('Yeni ürünler yükleniyor...')">Yeni Ürünler</button>
    </div>
  </div>

  
        <div class="slide-item">
          <div class="slide-placeholder-img">Görsel Alanı 2</div>
          <div class="slide-title">Yasuo Serisi</div>
          <div class="slide-desc">Rüzgârın oğlundan ilham alan sınırlı üretim tasarımlar.</div>
        </div>
        <div class="slide-item">
          <div class="slide-placeholder-img">Görsel Alanı 3</div>
          <div class="slide-title">Jinx Fırsatları</div>
          <div class="slide-desc">Patlayıcı fiyatlarla kaotik güzellik — acele et!</div>
        </div>
      </div>
    </div>
    <button class="slider-arrow prev" onclick="moveSlide(-1)">&#8249;</button>
    <button class="slider-arrow next" onclick="moveSlide(1)">&#8250;</button>
    <div class="slider-nav" id="sliderNav">
      <div class="slider-dot active" onclick="goToSlide(0)"></div>
      <div class="slider-dot" onclick="goToSlide(1)"></div>
      <div class="slider-dot" onclick="goToSlide(2)"></div>
    </div>
  </div>
  <div class="hero-divider"></div>
</div>

<div class="section reveal">
  <div class="section-header">
    <div class="section-title-wrap">
      <div class="ornament-diamond"></div>
      <span class="section-title">Kategoriler</span>
      <div class="section-line"></div>
    </div>
    <a href="#" class="view-all">Tümünü Gör &rarr;</a>
  </div>
  <div class="cat-grid" id="catGrid"></div>
</div>

<div class="section-divider"></div>

<div class="section reveal" style="padding-top:0">
  <div class="section-header">
    <div class="section-title-wrap">
      <div class="ornament-diamond"></div>
      <span class="section-title">Öne Çıkan Ürünler</span>
      <div class="section-line"></div>
    </div>
    <a href="#" class="view-all">Tümünü Gör &rarr;</a>
  </div>
  <div class="product-grid" id="productGrid">
  {% for product in collections.all.products limit: 4 %}
    
    <div class="product-card" style="animation-delay: {{ forloop.index0 | times: 0.1 | plus: 0.3 }}s;">
      
      {% if product.compare_at_price > product.price %}
        <div class="badge new-badge">İNDİRİM</div>
      {% elsif product.tags.first %}
        <div class="badge">{{ product.tags.first }}</div>
      {% endif %}

      <div class="product-img">
        <div class="product-glow"></div>
        <a href="{{ product.url }}" style="display: flex; align-items: center; justify-content: center; width: 100%; height: 100%;">
          {% if product.featured_image %}
            <img src="{{ product.featured_image | image_url: width: 400 }}" alt="{{ product.title }}" style="max-width: 85%; max-height: 85%; object-fit: contain; position: relative; z-index: 2; transition: transform 0.4s ease;">
          {% else %}
            <div class="img-placeholder-text">Görsel Bekleniyor</div>
          {% endif %}
        </a>
      </div>

      <div class="product-info">
        <div class="product-champion">{{ product.vendor | default: "Runeterra" }}</div>
        
        <div class="product-name">
          <a href="{{ product.url }}" style="color: inherit; text-decoration: none;">{{ product.title }}</a>
        </div>
        
        <div class="product-rating">
          <span class="stars">★★★★★</span>
          <span class="rating-count">(0)</span>
        </div>

        <div class="product-footer">
          <div class="price-wrap">
            <div class="price">
              {% if product.compare_at_price > product.price %}
                <span class="price-original">{{ product.compare_at_price | money }}</span>
              {% endif %}
              {{ product.price | money }}
            </div>
            <div class="price-rp">veya {{ product.price | divided_by: 10 }} RP</div>
          </div>
          
          <form method="post" action="/cart/add" style="margin: 0;">
            <input type="hidden" name="id" value="{{ product.variants.first.id }}" />
            <button type="submit" class="add-btn" data-name="{{ product.title | escape }}" onclick="addToCartReal(this)">+</button>
          </form>
        </div>
      </div>
    </div>

  {% else %}
    <p style="color: #C8AA6E; grid-column: span 4; text-align: center; font-size: 16px;">
      Vitrin bekliyor... Shopify panelinden ürün eklediğinizde burada belirecekler!
    </p>
  {% endfor %}
</div>
</div>

<div class="banner-section reveal">
  <div class="banner">
    <div class="banner-text">
      <div class="banner-label">&#x22C6; Özel Fırsat</div>
      <div class="banner-title">İlk Alışverişinde %20 İndirim</div>
      <div class="banner-desc">RIFTSTORE kodunu kullanarak ilk siparişinde %20 indirim kazan. Tüm koleksiyon ürünlerinde geçerlidir.</div>
    </div>
    <div class="banner-actions">
      <div>
        <div class="rp-amount">%20</div>
        <div class="rp-label">İlk Sipariş</div>
      </div>
      <button class="btn-primary" onclick="showToast('Kod kopyalandı: RIFTSTORE')">Kodu Kopyala</button>
    </div>
  </div>
</div>