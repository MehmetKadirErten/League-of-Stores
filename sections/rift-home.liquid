<div class="hero">
  <div class="hero-content">
    <div class="hero-tag">Sezon 2025 Koleksiyonu</div>
    <h1 class="hero-title">Runeterra'yı<br><span>Yanına Getir!</span></h1>
    <p class="hero-desc">Efsanevi şampiyonlardan ilham alan özel tasarım ürünler. Oyunun ruhunu günlük hayatına taşı.</p>
    <div class="hero-btns">
      <button class="btn-primary" onclick="showToast('Alışverişe yönlendiriliyorsunuz...')">Alışverişe Başla</button>
      <button class="btn-secondary" onclick="showToast('Yeni ürünler yükleniyor...')">Yeni Ürünler</button>
    </div>
  </div>

  <div class="hero-slider-wrap">
    <div class="hero-slider">
      <div class="slides-container" id="slidesContainer">
        <div class="slide-item">
          <div class="slide-placeholder-img">Görsel Alanı 1</div>
          <div class="slide-title">Ahri Koleksiyonu</div>
          <div class="slide-desc">Dokuz kuyruklu tilkiden ilham alan premium koleksiyon ürünleri.</div>
        </div>
        <div class="slide-item">
          <div class="slide-placeholder-img">Görsel Alanı 2</div>
          <div class="slide-title">Yasuo Serisi</div>
          <div class="slide-desc">Rüzgârın oğlundan ilham alan sınırlı üretim tasarımlar.</div>
        </div>
        <div class="slide-item">
          <div class="slide-placeholder-img">Görsel Alanı 3</div>
          <div class="slide-title">Jinx Fırsatları</div>
          <div class="slide-desc">Patlayıcı fiyatlarla kaotik güzellik — acele et!</div>
        </div>
      </div>
    </div>
    <button class="slider-arrow prev" onclick="moveSlide(-1)">&#8249;</button>
    <button class="slider-arrow next" onclick="moveSlide(1)">&#8250;</button>
    <div class="slider-nav" id="sliderNav">
      <div class="slider-dot active" onclick="goToSlide(0)"></div>
      <div class="slider-dot" onclick="goToSlide(1)"></div>
      <div class="slider-dot" onclick="goToSlide(2)"></div>
    </div>
  </div>
  <div class="hero-divider"></div>
</div>

<div class="section reveal">
  <div class="section-header">
    <div class="section-title-wrap">
      <div class="ornament-diamond"></div>
      <span class="section-title">Kategoriler</span>
      <div class="section-line"></div>
    </div>
    <a href="#" class="view-all">Tümünü Gör &rarr;</a>
  </div>
  <div class="cat-grid" id="catGrid"></div>
</div>

<div class="section-divider"></div>

<div class="section reveal" style="padding-top:0">
  <div class="section-header">
    <div class="section-title-wrap">
      <div class="ornament-diamond"></div>
      <span class="section-title">Öne Çıkan Ürünler</span>
      <div class="section-line"></div>
    </div>
    <a href="#" class="view-all">Tümünü Gör &rarr;</a>
  </div>
  <div class="product-grid" id="productGrid"></div>
</div>

<div class="banner-section reveal">
  <div class="banner">
    <div class="banner-text">
      <div class="banner-label">&#x22C6; Özel Fırsat</div>
      <div class="banner-title">İlk Alışverişinde %20 İndirim</div>
      <div class="banner-desc">RIFTSTORE kodunu kullanarak ilk siparişinde %20 indirim kazan. Tüm koleksiyon ürünlerinde geçerlidir.</div>
    </div>
    <div class="banner-actions">
      <div>
        <div class="rp-amount">%20</div>
        <div class="rp-label">İlk Sipariş</div>
      </div>
      <button class="btn-primary" onclick="showToast('Kod kopyalandı: RIFTSTORE')">Kodu Kopyala</button>
    </div>
  </div>
</div>

<script>
// Particles
(function(){
  var c=document.getElementById('particles');
  for(var i=0;i<18;i++){
    var p=document.createElement('div');
    p.className='particle';
    p.style.left=Math.random()*100+'%';
    p.style.width=p.style.height=(1+Math.random()*2)+'px';
    p.style.setProperty('--dur',(6+Math.random()*8)+'s');
    p.style.setProperty('--delay',(Math.random()*8)+'s');
    p.style.setProperty('--drift',((Math.random()-.5)*80)+'px');
    c.appendChild(p);
  }
})();

// Nav scroll
window.addEventListener('scroll',function(){
  document.getElementById('mainNav').classList.toggle('scrolled',window.scrollY>20);
},{passive:true});

// Categories
var cats=[
  {icon:'👕',name:'Giyim',count:'124 ürün'},
  {icon:'🏆',name:'Figürler',count:'87 ürün'},
  {icon:'💎',name:'Aksesuar',count:'95 ürün'},
  {icon:'🃏',name:'Koleksiyon',count:'63 ürün'},
  {icon:'🎁',name:'Hediyeler',count:'42 ürün'}
];
(function(){
  var g=document.getElementById('catGrid');
  cats.forEach(function(cat,i){
    var d=document.createElement('div');
    d.className='cat-card';
    d.style.animationDelay=(i*.08)+'s';
    d.innerHTML='<span class="cat-icon">'+cat.icon+'</span><div class="cat-name">'+cat.name+'</div><div class="cat-count">'+cat.count+'</div>';
    d.onclick=function(){showToast(cat.name+' kategorisine gidiliyor...');};
    g.appendChild(d);
  });
})();

// Products
var prods=[
  {champ:'Ahri',name:'Kuyruk Kolye',price:'299',rp:'3.000',stars:5,reviews:48,badge:null,orig:null},
  {champ:'Yasuo',name:'Rüzgar Kılıcı Figür',price:'849',rp:'8.500',stars:4,reviews:32,badge:'YENİ',orig:null},
  {champ:'Jinx',name:'Fishbones Çanta',price:'549',rp:'5.500',stars:5,reviews:71,badge:null,orig:'699'},
  {champ:'Mordekaiser',name:'Metal Kupa Seti',price:'449',rp:'4.500',stars:4,reviews:19,badge:null,orig:null}
];
(function(){
  var g=document.getElementById('productGrid');
  prods.forEach(function(p,i){
    var stars='★'.repeat(p.stars)+'☆'.repeat(5-p.stars);
    var badge=p.badge?'<div class="badge new-badge">'+p.badge+'</div>':'';
    var orig=p.orig?'<span class="price-original">&#x20BA;'+p.orig+'</span>':'';
    var d=document.createElement('div');
    d.className='product-card';
    d.style.animationDelay=(.3+i*.1)+'s';
    d.innerHTML=badge+'<div class="product-img"><div class="product-glow"></div><div class="img-placeholder-text">Görsel Eklenecek</div></div><div class="product-info"><div class="product-champion">'+p.champ+'</div><div class="product-name">'+p.name+'</div><div class="product-rating"><span class="stars">'+stars+'</span><span class="rating-count">('+p.reviews+')</span></div><div class="product-footer"><div class="price-wrap"><div class="price">'+orig+'&#x20BA;'+p.price+'</div><div class="price-rp">veya '+p.rp+' RP</div></div><button class="add-btn" data-name="'+p.name+'">+</button></div></div>';
    g.appendChild(d);
  });
  document.querySelectorAll('.add-btn').forEach(function(btn){
    btn.addEventListener('click',function(e){
      e.stopPropagation();
      if(this.classList.contains('added'))return;
      var n=this.getAttribute('data-name');
      this.classList.add('added');
      this.textContent='✓';
      var cc=document.getElementById('cartCount');
      cc.textContent=parseInt(cc.textContent)+1;
      showToast(n+' sepete eklendi!');
      var self=this;
      setTimeout(function(){self.classList.remove('added');self.textContent='+';},2000);
    });
  });
})();

// Slider
var cur=0,total=3,timer=null;
function goToSlide(i){
  cur=(i+total)%total;
  document.getElementById('slidesContainer').style.transform='translateX(-'+(cur*100)+'%)';
  document.querySelectorAll('.slider-dot').forEach(function(d,idx){d.classList.toggle('active',idx===cur);});
}
function moveSlide(d){resetTimer();goToSlide(cur+d);}
function resetTimer(){clearInterval(timer);timer=setInterval(function(){goToSlide(cur+1);},4500);}
resetTimer();

// Champion search
function filterChampions(){
  var v=document.getElementById('champSearchInput').value.toLowerCase();
  var items=document.getElementById('champListContainer').getElementsByClassName('champ-item');
  for(var i=0;i<items.length;i++){
    var n=items[i].getElementsByTagName('span')[0].innerText.toLowerCase();
    items[i].style.display=n.indexOf(v)>-1?'flex':'none';
  }
}

// Toast
var tTimer=null;
function showToast(msg){
  var t=document.getElementById('toast');
  document.getElementById('toastMsg').textContent=msg;
  t.classList.add('show');
  clearTimeout(tTimer);
  tTimer=setTimeout(function(){t.classList.remove('show');},2800);
}

// Scroll reveal
(function(){
  var els=document.querySelectorAll('.reveal');
  var obs=new IntersectionObserver(function(entries){
    entries.forEach(function(e){if(e.isIntersecting){e.target.classList.add('visible');obs.unobserve(e.target);}});
  },{threshold:.1});
  els.forEach(function(el){obs.observe(el);});
})();
</script>