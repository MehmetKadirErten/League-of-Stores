<script>
// Mega Menu Arama/Filtreleme İşlevi
function filterChampions() {
  let input = document.getElementById('champSearchInput').value.toLowerCase();
  let items = document.getElementById('champListContainer').getElementsByClassName('champ-item');
  
  for (let i = 0; i < items.length; i++) {
    let name = items[i].getElementsByTagName("span")[0].innerText.toLowerCase();
    if (name.indexOf(input) > -1) {
      items[i].style.display = "flex";
    } else {
      items[i].style.display = "none";
    }
  }
}

// Sepete Ekle Butonu Efekti
document.querySelectorAll('.add-btn').forEach(btn => {
  btn.addEventListener('click', function(e) {
    e.stopPropagation();
    this.textContent = '✓';
    this.style.color = '#C89B3C';
    this.style.borderColor = '#C89B3C';
    setTimeout(() => { this.textContent = '+'; this.style.color = ''; this.style.borderColor = ''; }, 1500);
  });
});
</script>