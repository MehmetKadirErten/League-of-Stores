{% comment %} main-product.liquid {% endcomment %}
<div class="pg-root" id="root">
  <div class="bg-particles" id="particles"></div>

  <div class="pg-header">
    <div class="breadcrumb">MAĞAZA <span>/ {{ product.type | upcase }}</span></div>
    <button class="wishlist-btn" id="wishlistBtn" onclick="toggleWishlist()">
      <span class="heart">♡</span> İSTEK LİSTESİ
    </button>
  </div>

  <div class="pg-body">
    <div class="gallery">
      <div class="main-img-wrap">
        <div class="badge-new">YENİ SEZON</div>
        <img src="{{ product.featured_image | image_url: width: 800 }}" alt="{{ product.title }}">
        <div class="zoom-hint">🔍 YAKLAŞTIR</div>
      </div>
      <div class="thumbnails">
        {% for image in product.images limit: 4 %}
        <div class="thumb {% if forloop.first %}active{% endif %}">
            <img src="{{ image | image_url: width: 100 }}" alt="{{ image.alt }}">
        </div>
        {% endfor %}
      </div>
    </div>

    <div class="info">
      <div class="faction-tag">{{ product.vendor | upcase }}</div>
      <h1 class="product-title">{{ product.title }}</h1>

      <div class="rating-row">
        <span class="stars">★★★★★</span>
        <span style="font-size:14px; color:#C8AA6E; font-weight:600;">4.8</span>
        <span class="rating-count" onclick="document.getElementById('reviews-section').scrollIntoView({behavior:'smooth'})">(247 yorum)</span>
      </div>

      <div class="price-row">
        <span class="price-main">{{ product.price | money }}</span>
        {% if product.compare_at_price > product.price %}
            <span class="price-old">{{ product.compare_at_price | money }}</span>
        {% endif %}
      </div>

      <p class="desc">{{ product.description }}</p>

      {% form 'product', product %}
        <div class="action-row">
          <div class="qty-wrap">
            <button type="button" class="qty-btn" onclick="changeQty(-1)">−</button>
            <input type="number" name="quantity" value="1" class="qty-num" id="qtyNum" min="1" readonly>
            <button type="button" class="qty-btn" onclick="changeQty(1)">+</button>
          </div>
          <button type="submit" class="btn-add" id="addBtn">
            <span class="shine"></span>
            SEPETE EKLE
          </button>
        </div>
      {% endform %}
    </div>
  </div>
</div>

<script>
// (Senin verdiğin JS kodlarının tamamını buraya yapıştır)
// SadeceaddToCart fonksiyonunu Shopify formuna uyarladık, 
// form zaten çalışacaktır.
