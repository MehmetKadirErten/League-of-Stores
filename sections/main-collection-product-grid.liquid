{{ 'template-collection.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

<div class="collection-container">
  
  <div class="collection-header">
    <div class="ornament-diamond" style="width:10px; height:10px; background: var(--gold-bright); transform: rotate(45deg); margin: 0 auto 15px;"></div>
    <h1 class="collection-title">{{ collection.title | upcase }}</h1>
    
    {%- if collection.description != blank -%}
      <p class="collection-desc">{{ collection.description }}</p>
    {%- endif -%}
    
    <div class="collection-count">{{ collection.products_count }} Eser Bulundu</div>
  </div>

  {%- paginate collection.products by 24 -%}
  <div class="product-grid">
    {%- for product in collection.products -%}
      
      <div class="product-card" style="animation-delay: {{ forloop.index0 | times: 0.1 | plus: 0.2 }}s;" onclick="window.location.href='{{ product.url }}'">
        
        {%- if product.compare_at_price != blank and product.compare_at_price > product.price -%}
          <div class="badge new-badge">İNDİRİM</div>
        {%- elsif product.tags.first -%}
          <div class="badge">{{ product.tags.first }}</div>
        {%- endif -%}

        <div class="product-img">
          <div class="product-glow"></div>
          <a href="{{ product.url }}" style="display: flex; align-items: center; justify-content: center; width: 100%; height: 100%;" onclick="event.stopPropagation();">
            {%- if product.featured_image -%}
              <img src="{{ product.featured_image | image_url: width: 400 }}" alt="{{ product.title | escape }}" style="max-width: 85%; max-height: 85%; object-fit: contain; position: relative; z-index: 2; transition: transform 0.4s ease;">
            {%- else -%}
              <div class="img-placeholder-text">Görsel Bekleniyor</div>
            {%- endif -%}
          </a>
        </div>

        <div class="product-info">
          <div class="product-champion">{{ product.vendor | default: "Runeterra" }}</div>
          
          <div class="product-name">
            <a href="{{ product.url }}" style="color: inherit; text-decoration: none;" onclick="event.stopPropagation();">{{ product.title }}</a>
          </div>
          
          <div class="product-rating">
            <span class="stars">★★★★★</span>
            <span class="rating-count">(0)</span>
          </div>

          <div class="product-footer">
            <div class="price-wrap">
              <div class="price">
                {%- if product.compare_at_price != blank and product.compare_at_price > product.price -%}
                  <span class="price-original">{{ product.compare_at_price | money }}</span>
                {%- endif -%}
                {{ product.price | money }}
              </div>
              <div class="price-rp">veya {{ product.price | divided_by: 10 }} RP</div>
            </div>
            
            <form method="post" action="/cart/add" style="margin: 0;" onclick="event.stopPropagation();">
              <input type="hidden" name="id" value="{{ product.variants.first.id }}" />
              <button type="submit" class="add-btn" data-name="{{ product.title | escape }}" onclick="addToCartReal(this)">+</button>
            </form>
          </div>
        </div>
      </div>

    {%- else -%}
      <p style="color: #C8AA6E; grid-column: span 4; text-align: center; font-size: 16px; padding: 60px 0;">
        Bu koridorda henüz hiçbir ürün bulunmuyor. Shopify panelinden bu koleksiyona ürün eklediğinizde burada belirecektir!
      </p>
    {%- endfor -%}
  </div>
  {%- endpaginate -%}
</div>

{% schema %}
{
  "name": "Product Grid",
  "settings": []
}
{% endschema %}